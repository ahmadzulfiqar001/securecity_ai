# SecureCity AI — environment variables for docker-compose.yml
#
# Copy this file to `.env` and fill in real values. Variables marked
# REQUIRED have no default in docker-compose.yml — `docker compose up`
# will refuse to start without them (see CRIT-02 in the architecture
# audit: previously these shipped with guessable defaults baked into
# the compose file itself).

# ── Redis ──────────────────────────────────────────────
# REQUIRED. Used by ai_engine, cv_engine, and redis_commander (dev profile).
REDIS_PASSWORD=

# ── MongoDB (ai_engine/cv_engine internal ML data only — not app data) ──
MONGO_ROOT_USER=mongoadmin
# REQUIRED.
MONGO_ROOT_PASSWORD=
MONGO_DB=securecity_ml
# Optional. How many daily mongodump archives the mongodb-backup sidecar
# keeps before pruning (default: 14).
MONGO_BACKUP_RETENTION_DAYS=14

# Least-privilege user (readWrite on MONGO_DB only) that ai_engine/cv_engine
# actually connect as — see infrastructure/mongodb/init/init-app-user.js.
# Only auto-created on a FRESH deployment; see that script's header for the
# manual migration path on an existing one. REQUIRED.
MONGO_APP_USER=securecity_ml_app
MONGO_APP_PASSWORD=

# ── Grafana ────────────────────────────────────────────
GRAFANA_USER=admin
# REQUIRED.
GRAFANA_PASSWORD=

# ── Redis Commander (dev profile only) ────────────────
REDIS_COMMANDER_USER=admin
# REQUIRED if you run the `dev` compose profile.
REDIS_COMMANDER_PASSWORD=

# ── Firebase Admin SDK (server-side ID token verification) ──
# Path on the HOST to a Firebase service-account credentials JSON file.
# Mounted read-only into ai_engine/cv_engine at
# /run/secrets/firebase_credentials.json.
FIREBASE_CREDENTIALS_HOST_PATH=./secrets/firebase_credentials.json

# ── Internal service-to-service auth ──────────────────
# Shared secret ai_engine/cv_engine use to authenticate trusted callers
# (e.g. Cloud Functions) on /internal/* and /training/* routes.
# REQUIRED — see HIGH-01 in the architecture audit.
INTERNAL_SERVICE_TOKEN=

# ── Domain (used by Grafana's root URL and nginx/Certbot) ──
DOMAIN=localhost
