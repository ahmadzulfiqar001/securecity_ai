rules_version = '2';

// ============================================================
// SecureCity AI — Firestore Security Rules
//
// Roles (custom claim `role` on the Firebase Auth token, set via
// Cloud Functions / Admin SDK — never client-writable):
//   CITIZEN   — default role for the mobile app
//   POLICE, AMBULANCE, FIRE, ADMIN — authority roles
// ============================================================

function isSignedIn() {
  return request.auth != null;
}

function uid() {
  return request.auth.uid;
}

function role() {
  return request.auth.token.role;
}

function isAuthority() {
  return isSignedIn() && role() in ['POLICE', 'AMBULANCE', 'FIRE', 'ADMIN'];
}

function isAdmin() {
  return isSignedIn() && role() == 'ADMIN';
}

function isOwner(userId) {
  return isSignedIn() && uid() == userId;
}

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────
    // Doc id == Firebase UID. Users manage their own profile;
    // authorities can read profiles for incident triage.
    // Emergency contacts are an embedded list field on this document
    // (UserModel.emergencyContacts), not a subcollection — covered by the
    // read/update rules below, not a separate match block.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAuthority();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /journey_history/{journeyId} {
        allow read, write: if isOwner(userId);
        allow read: if isAuthority();
      }
    }

    // ── Incidents / Crime Reports ─────────────────────────
    // Citizens create and read their own reports (or anonymous ones);
    // authorities can read and triage all reports.
    match /incidents/{incidentId} {
      allow read: if isSignedIn() &&
        (resource.data.reporterId == uid() || resource.data.isAnonymous == true || isAuthority());
      allow create: if isSignedIn() && request.resource.data.reporterId == uid();
      // Citizen owners may only edit their own PENDING report, and may not
      // reassign it to another reporter (reporterId pinned immutable).
      allow update: if isAuthority() ||
        (isOwner(resource.data.reporterId) && resource.data.status == 'PENDING' &&
         request.resource.data.reporterId == resource.data.reporterId);
      allow delete: if isAdmin();
    }

    // ── SOS Events ─────────────────────────────────────────
    // Highest-sensitivity collection: only the triggering user and
    // authorities may read; only the triggering user may create.
    match /sos_events/{sosId} {
      allow read: if isSignedIn() && (resource.data.userId == uid() || isAuthority());
      allow create: if isSignedIn() && request.resource.data.userId == uid();
      // Owner updates may not reassign the event to another user (userId
      // pinned immutable).
      allow update: if isAuthority() ||
        (isOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId);
      allow delete: if isAdmin();
    }

    // ── Notifications ──────────────────────────────────────
    // Per-user notification feed; only Cloud Functions / authorities write.
    match /notifications/{notificationId} {
      allow read, update: if isSignedIn() && resource.data.userId == uid();
      allow create: if isAuthority();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // ── Safety Alerts / Area Safety / Heatmaps ─────────────
    // Broadcast, read-only data generated by the AI/CV microservices
    // (via Admin SDK, which bypasses these rules) or authorities.
    match /safety_alerts/{alertId} {
      allow read: if isSignedIn();
      allow write: if isAuthority();
    }

    match /area_safety/{areaId} {
      allow read: if isSignedIn();
      allow write: if isAuthority();
    }

    // ── Nearby Services (police stations, hospitals, shelters) ─
    match /nearby_services/{serviceId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Map Zones (emergency / flood_risk / traffic polygons) ─
    // Authority-drawn zones, managed via the dashboard's Zone Manager.
    // Read access is broad (not just isAuthority()) because mobile needs
    // to read active zones for both display and client-side geofencing.
    // Any authority (not just the original creator) can edit/delete — a
    // shared team resource, same as cctv_cameras/nearby_services below.
    match /map_zones/{zoneId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAuthority();
    }

    // ── AI Chatbot History ──────────────────────────────────
    match /chat_messages/{messageId} {
      // NOTE: `request.resource.data` is only valid on create/update, never
      // on read — the previous combined `read, create` rule used it for
      // both, which meant `resource.data.userId` was never checked on read
      // and every read silently evaluated to false. Split so read uses
      // `resource.data` (the existing document) and create uses
      // `request.resource.data` (the incoming write).
      allow read: if isSignedIn() && resource.data.userId == uid();
      allow create: if isSignedIn() && request.resource.data.userId == uid();
      allow update, delete: if false;
    }

    // ── User Activity (analytics/audit trail) ──────────────
    // Written by Cloud Functions / Admin SDK only; never client-writable.
    match /user_activity/{activityId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if false;
    }

    // ── CCTV Cameras / Traffic / Weather (authority-managed refs) ─
    match /cctv_cameras/{cameraId} {
      allow read: if isAuthority();
      allow write: if isAdmin();
    }

    match /traffic_data/{docId} {
      allow read: if isSignedIn();
      allow write: if isAuthority();
    }

    match /weather_data/{docId} {
      allow read: if isSignedIn();
      allow write: if isAuthority();
    }

    // ── Audit Logs ──────────────────────────────────────────
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
