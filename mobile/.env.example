# ============================================================
# SecureCity AI — Mobile App: External API / Config Reference
#
# IMPORTANT: Flutter does NOT read .env files by itself (no
# flutter_dotenv/envied package is in pubspec.yaml). This file is
# documentation only — it lists every external API key/config this
# app needs and the EXACT file you must actually edit to wire it in.
# Filling in values here alone does nothing.
#
# Already covered by the root .gitignore (`.env` / `.env.*` /
# `!.env.example`), so a real `.env` you copy this to for your own
# notes/password-manager reference won't get committed.
# ============================================================

# ── Map tiles (OpenStreetMap) ────────────────────────────────
# Used by: lib/features/map/presentation/map_screen.dart (flutter_map + latlong2)
# STATUS: no key/billing needed. Tiles are fetched from the public OSM tile
#         server (tile.openstreetmap.org) using the app's package id as the
#         User-Agent, per OSM's tile usage policy. Nothing to configure here.
#         If tile traffic grows beyond OSM's fair-use policy, switch
#         urlTemplate in map_screen.dart to a paid tile provider
#         (MapTiler/Stadia/Mapbox) instead of self-hosting.

# ── Firebase ─────────────────────────────────────────────────
# Used by: Auth, Firestore, Storage, FCM, Analytics, Crashlytics, Remote Config
# (basically every feature).
# STATUS:
#   Android — configured: android/app/google-services.json + lib/firebase_options.dart
#             (project city-ai-968bd).
#   iOS     — lib/firebase_options.dart has iOS keys, but ios/Runner/GoogleService-Info.plist
#             is MISSING from disk. Needed if any native iOS build/pod step expects it.
#
# Nothing to hand-edit here — if keys ever rotate, regenerate via:
#   flutterfire configure
# from inside mobile/. Don't hand-edit lib/firebase_options.dart directly.

# ── Google Sign-In ───────────────────────────────────────────
# Used by: lib/features/authentication/data/repositories/auth_repository_impl.dart
#          (the "Continue with Google" button on the login screen)
# STATUS: NOT fully configured. android/app/google-services.json has an empty
#         "oauth_client": [], and ios/Runner/Info.plist has no GIDClientID /
#         URL scheme. Google Sign-In will fail until this is set up.
GOOGLE_SIGNIN_WEB_CLIENT_ID=

#   Firebase Console -> Authentication -> Sign-in method -> Google -> Enable,
#   then re-download google-services.json (Android) so oauth_client gets
#   populated, and download GoogleService-Info.plist (iOS) and add its
#   REVERSED_CLIENT_ID as a URL scheme in ios/Runner/Info.plist
#   (CFBundleURLTypes).

# ── AI Prediction Engine (crime heatmap / safe-route scoring) ─
# Used by: lib/core/network/api_client.dart
#          lib/features/map/data/repositories/predictions_repository_impl.dart
#          (calls POST /predict/heatmap and /predict/route-safety)
# STATUS: placeholder only. These are NOT real deployed endpoints — the
#         ai_engine/cv_engine backend was set aside for now (mobile-only
#         focus, see git commit d54ee51). The map screen's heatmap toggle
#         and "Calculate Safe Route" button will fail/show an error until
#         a real service exists at one of these URLs.
API_BASE_URL=https://api.securecity.ai/v1
API_BASE_URL_DEV=https://dev-api.securecity.ai/v1
API_BASE_URL_STAGING=https://staging-api.securecity.ai/v1

#   Update the hardcoded values in
#   lib/core/constants/app_constants.dart (apiBaseUrl / apiBaseUrlDev /
#   apiBaseUrlStaging) once a real ai_engine endpoint exists.

# ── CI: Codecov ──────────────────────────────────────────────
# Used by: .github/workflows/ci.yml (coverage upload step)
# STATUS: this is a GitHub Actions secret, NOT an app-level value — set it
#         in the GitHub repo under Settings -> Secrets and variables ->
#         Actions -> New repository secret -> name it CODECOV_TOKEN.
CODECOV_TOKEN=
